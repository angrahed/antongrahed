---
import type { ImageMetadata } from "astro";
import { getImage, Image } from "astro:assets";
import PageLayout from "@/layouts/Base.astro";

const filmModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/film/*.{jpg,jpeg,png,gif,webp,avif,JPG,JPEG,PNG,GIF,WEBP,AVIF}",
	{ eager: true },
);

// magazine-spread stagger on lg+: wide left / narrow right / indented wide, repeating
const spread = [
	"lg:col-start-1 lg:col-span-7",
	"lg:col-start-8 lg:col-span-5",
	"lg:col-start-3 lg:col-span-7",
];

const galleryImages = await Promise.all(
	Object.entries(filmModules)
		.sort(([a], [b]) => a.localeCompare(b))
		.map(async ([path, mod], index) => {
			const filename = (path.split("/").pop() ?? "film-photo").replace(/\.[^/.]+$/, "");
			const parts = filename.split(/[-_]+/);
			// filenames follow YYYY_MM_location-name
			const hasDate =
				parts.length > 2 && /^\d{4}$/.test(parts[0] ?? "") && /^\d{1,2}$/.test(parts[1] ?? "");
			const location = (hasDate ? parts.slice(2) : parts)
				.join(" ")
				.replace(/(\d+)$/, " $1")
				.trim();
			const date = hasDate ? `${parts[1]?.padStart(2, "0")}/${parts[0]}` : "";
			const frame = String(index + 1).padStart(2, "0");

			// pre-sized lightbox rendition so full-screen view doesn't load multi-MB originals
			const lightbox = await getImage({ format: "webp", src: mod.default, width: 2000 });

			return {
				alt: `Film photograph — ${location}`,
				caption: `Frame ${frame} · ${location}`,
				date,
				lightboxSrc: lightbox.src,
				placement: spread[index % spread.length],
				src: mod.default,
			};
		}),
);
---

<PageLayout meta={{ title: "Film Photography" }}>
	<section class="border-border border-b">
		<div class="shell py-16 md:py-24">
			<p class="eyebrow reveal">Film Photography</p>
			<h1 class="title reveal mt-4 [animation-delay:80ms]">Shot on film</h1>
			<p class="lead reveal text-text-secondary mt-6 max-w-[40rem] [animation-delay:160ms]">
				A rolling selection from my negatives. 35mm from near and far, mostly on a Nikon F5,
				Nikon FA, Nikon FM2N and an Olympus Mju II.
			</p>
		</div>
	</section>

	<section>
		<div class="shell py-16 md:py-24">
			{
				galleryImages.length === 0 ? (
					<p class="text-text-secondary text-sm">No film photos yet. Fresh scans are on their way.</p>
				) : (
					<div class="grid gap-x-8 gap-y-16 lg:grid-cols-12">
						{galleryImages.map(({ alt, caption, date, lightboxSrc, placement, src }) => (
							<button
								class={`group block w-full cursor-zoom-in text-left ${placement}`}
								data-film-alt={alt}
								data-film-caption={`${caption}${date ? ` · ${date}` : ""}`}
								data-film-src={lightboxSrc}
								data-film-trigger
								type="button"
							>
								<Image
									alt={alt}
									class="h-auto w-full"
									decoding="async"
									loading="lazy"
									sizes="(min-width: 1024px) 60vw, calc(100vw - 2rem)"
									src={src}
									widths={[640, 1024, 1600]}
								/>
								<span class="border-border mt-3 flex items-baseline justify-between gap-4 border-t pt-2">
									<span class="eyebrow ease-productive group-hover:text-link transition-colors duration-100">
										{caption}
									</span>
									{date && <span class="eyebrow shrink-0">{date}</span>}
								</span>
							</button>
						))}
					</div>
				)
			}
		</div>
	</section>

	<div
		aria-hidden="true"
		class="fixed inset-0 z-50 hidden items-center justify-center bg-[#161616]/95 p-4 transition-opacity duration-200"
		id="film-lightbox"
	>
		<button
			aria-label="Close enlarged photo"
			class="ease-productive absolute top-4 right-4 z-10 flex h-12 w-12 cursor-pointer items-center justify-center text-[#f4f4f4] transition-colors duration-100 hover:bg-[#393939]"
			data-film-close
			type="button"
		>
			<svg
				aria-hidden="true"
				class="h-5 w-5"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
			</svg>
		</button>
		<figure class="flex max-h-full max-w-full flex-col gap-3">
			<img alt="" class="max-h-[85vh] max-w-[92vw] object-contain" data-film-active />
			<figcaption
				class="font-mono text-xs tracking-[0.1em] text-[#c6c6c6] uppercase"
				data-film-lightbox-caption
			>
			</figcaption>
		</figure>
	</div>
</PageLayout>

<style>
	@media (prefers-reduced-motion: no-preference) {
		#film-lightbox[aria-hidden="false"] img {
			animation: lightbox-zoom 240ms var(--ease-expressive) both;
		}

		[data-film-active] {
			transition: filter 320ms ease-out;
		}

		[data-film-active].is-loading {
			filter: blur(14px);
		}
	}

	@keyframes lightbox-zoom {
		from {
			opacity: 0;
			transform: scale(0.97);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}
</style>

<script>
	const lightbox = document.getElementById("film-lightbox");
	if (lightbox) {
		const activeImg = lightbox.querySelector<HTMLImageElement>("[data-film-active]");
		const captionEl = lightbox.querySelector("[data-film-lightbox-caption]");
		const closeBtn = lightbox.querySelector<HTMLButtonElement>("[data-film-close]");
		const triggers = document.querySelectorAll<HTMLButtonElement>("[data-film-trigger]");
		let lastFocused: HTMLButtonElement | null = null;

		// Warm the full-size scan on hover/focus so it is usually ready by click.
		const preloaded = new Set<string>();
		const warm = (trigger: HTMLButtonElement) => {
			const src = trigger.dataset.filmSrc;
			if (!src || preloaded.has(src)) return;
			preloaded.add(src);
			new Image().src = src;
		};

		const open = (trigger: HTMLButtonElement) => {
			if (!activeImg) return;
			const highSrc = trigger.dataset.filmSrc ?? "";
			const alt = trigger.dataset.filmAlt ?? "";
			const caption = trigger.dataset.filmCaption ?? "";
			const thumb = trigger.querySelector<HTMLImageElement>("img");
			const thumbSrc = thumb?.currentSrc || thumb?.getAttribute("src") || highSrc;

			lastFocused = trigger;
			activeImg.dataset.target = highSrc;

			// Show the already-decoded grid thumbnail instantly (blurred) so the
			// panel never opens on a blank frame while the full scan downloads.
			activeImg.setAttribute("src", thumbSrc);
			activeImg.setAttribute("alt", alt);
			activeImg.classList.add("is-loading");
			if (captionEl) captionEl.textContent = caption;

			lightbox.classList.remove("hidden");
			lightbox.classList.add("flex");
			lightbox.setAttribute("aria-hidden", "false");
			document.body.style.overflow = "hidden";
			window.setTimeout(() => closeBtn?.focus(), 0);

			if (!highSrc || thumbSrc === highSrc) {
				activeImg.classList.remove("is-loading");
				return;
			}

			// Swap to the full scan once it has fully decoded, then unblur.
			const full = new Image();
			full.src = highSrc;
			const reveal = () => {
				if (!activeImg || activeImg.dataset.target !== highSrc) return;
				activeImg.setAttribute("src", highSrc);
				activeImg.classList.remove("is-loading");
			};
			full.decode().then(reveal).catch(reveal);
		};

		const close = () => {
			if (!activeImg) return;
			activeImg.dataset.target = "";
			activeImg.removeAttribute("src");
			activeImg.setAttribute("alt", "");
			activeImg.classList.remove("is-loading");
			if (captionEl) captionEl.textContent = "";
			lightbox.classList.remove("flex");
			lightbox.classList.add("hidden");
			lightbox.setAttribute("aria-hidden", "true");
			document.body.style.overflow = "";
			lastFocused?.focus();
		};

		triggers.forEach((trigger) => {
			trigger.addEventListener("pointerenter", () => warm(trigger));
			trigger.addEventListener("focus", () => warm(trigger));

			trigger.addEventListener("click", () => open(trigger));

			trigger.addEventListener("keydown", (event) => {
				if (event.key === "Enter" || event.key === " ") {
					event.preventDefault();
					trigger.click();
				}
			});
		});

		closeBtn?.addEventListener("click", close);

		lightbox.addEventListener("click", (event) => {
			if (event.target === lightbox) {
				close();
			}
		});

		window.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && lightbox.getAttribute("aria-hidden") === "false") {
				close();
			}
		});
	}
</script>
