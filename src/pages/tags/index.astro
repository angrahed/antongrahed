---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	description: "A list of all the topics I've written about in my posts",
	title: "All Tags",
};
---

<PageLayout meta={meta}>
	<section class="border-border border-b">
		<div class="shell py-16 md:py-24">
			<p class="eyebrow reveal">Writing</p>
			<h1 class="title reveal mt-4 [animation-delay:80ms]">Tags</h1>
		</div>
	</section>
	<section>
		<div class="shell py-16 md:py-24">
			<ul class="max-w-[42rem]">
				{
					allTags.map(([tag, val]) => (
						<li class="border-border flex items-baseline gap-x-3 border-t py-3">
							<a
								class="cactus-link font-mono text-sm"
								href={`/tags/${tag}/`}
								title={`View posts with the tag: ${tag}`}
							>
								&#35;{tag}
							</a>
							<span class="text-text-secondary font-mono text-xs tracking-[0.1em] uppercase">
								{val} Post{val > 1 && "s"}
							</span>
						</li>
					))
				}
			</ul>
		</div>
	</section>
</PageLayout>
