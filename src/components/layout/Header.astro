---
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { menuLinks, siteConfig } from "@/site.config";

const navLink =
	"ease-productive flex h-12 items-center border-t border-border px-4 text-sm text-text-secondary transition-colors duration-100 hover:bg-surface hover:text-global-text aria-[current=page]:border-l-4 aria-[current=page]:border-l-[#0f62fe] aria-[current=page]:text-global-text sm:border-t-0 sm:aria-[current=page]:border-l-0 sm:aria-[current=page]:shadow-[inset_0_-2px_0_0_#0f62fe]";
---

<header
	class="group border-border bg-global-bg sticky top-0 z-50 w-full border-b"
	id="main-header"
>
	<div class="mx-auto flex h-12 w-full max-w-[99rem] items-stretch md:px-4">
		<a
			aria-current={Astro.url.pathname === "/" ? "page" : false}
			class="ease-productive hover:bg-surface flex items-center px-4 text-sm whitespace-nowrap transition-colors duration-100"
			href="/"
		>
			<span class="font-semibold">{siteConfig.title}</span><span
				class="text-text-secondary hidden md:inline">&nbsp;·&nbsp;Economics</span
			><span class="text-accent font-semibold">.</span>
		</a>
		<nav
			aria-label="Main menu"
			class="border-border bg-global-bg absolute inset-x-0 top-full hidden flex-col border-b group-[.menu-open]:flex sm:static sm:flex sm:flex-row sm:items-stretch sm:border-b-0 sm:bg-transparent"
			id="navigation-menu"
		>
			{
				menuLinks.map((link) => (
					<a
						aria-current={Astro.url.pathname === link.path ? "page" : false}
						class={navLink}
						href={link.path}
					>
						{link.title}
					</a>
				))
			}
		</nav>
		<div class="ms-auto flex items-stretch">
			<Search />
			<ThemeToggle />
			<mobile-button class="flex items-stretch sm:hidden">
				<button
					aria-expanded="false"
					aria-haspopup="menu"
					class="group/btn border-border ease-productive hover:bg-surface relative flex h-12 w-12 cursor-pointer items-center justify-center border-l transition-colors duration-100"
					id="toggle-navigation-menu"
					type="button"
				>
					<span class="sr-only">Open main menu</span>
					<svg
						aria-hidden="true"
						class="h-5 w-5 group-aria-expanded/btn:hidden"
						fill="none"
						focusable="false"
						id="line-svg"
						stroke="currentColor"
						stroke-width="1.5"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path d="M3.75 9h16.5m-16.5 6.75h16.5" stroke-linecap="round" stroke-linejoin="round"
						></path>
					</svg>
					<svg
						aria-hidden="true"
						class="hidden h-5 w-5 group-aria-expanded/btn:block"
						fill="none"
						focusable="false"
						id="cross-svg"
						stroke="currentColor"
						stroke-width="1.5"
						viewBox="0 0 24 24"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</button>
			</mobile-button>
		</div>
	</div>
</header>

<script>
	import { toggleClass } from "@/utils/domElement";

	class MobileNavBtn extends HTMLElement {
		#menuOpen: boolean = false;

		connectedCallback() {
			const headerEl = document.getElementById("main-header")!;
			const mobileButtonEl = this.querySelector<HTMLButtonElement>("button");

			mobileButtonEl?.addEventListener("click", () => {
				if (headerEl) toggleClass(headerEl, "menu-open");
				this.#menuOpen = !this.#menuOpen;
				mobileButtonEl.setAttribute("aria-expanded", this.#menuOpen.toString());
			});
		}
	}

	customElements.define("mobile-button", MobileNavBtn);
</script>
